# ==========================================================================
# PriceSwitch - Static configuration (.env)
# Copy this file to ".env" and adjust the values.
# These are settings that change rarely and are NOT editable from the web UI.
# Frequently changed settings are managed on the web Settings page.
# ==========================================================================

# --- Web server ---
HOST=0.0.0.0
PORT=8000

# --- Security ---
# Secret key used to sign session cookies. CHANGE THIS to a long random string!
SECRET_KEY=change-me-to-a-long-random-string

# Require login to access the web interface (true/false)
AUTH_REQUIRED=false
# Password for the web interface (only used when AUTH_REQUIRED=true)
AUTH_PASSWORD=admin

# --- Files ---
# Path to the JSON file holding user-editable settings.
CONFIG_FILE=config.json
# Path to the SQLite database holding the switch-event log.
DB_FILE=priceswitch.db
# Application log file.
LOG_FILE=priceswitch.log
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- GPIO electrical configuration ---
# Relay boards are often "active low" (GPIO LOW energises the relay).
# Set to "true" for active-low boards, "false" for active-high.
GPIO_ACTIVE_LOW=true

# --- Provider API keys (only needed for providers that require a key) ---
# Tibber personal access token (https://developer.tibber.com)
TIBBER_TOKEN=
# ENTSO-E security token (https://transparency.entsoe.eu)
ENTSOE_TOKEN=
